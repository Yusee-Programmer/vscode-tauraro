{
  "$schema": "vscode://schemas/color-theme",
  "name": "Tauraro Dark (Java Style)",
  "type": "dark",

  "colors": {
    "editor.background":                          "#2B2B2B",
    "editor.foreground":                          "#A9B7C6",
    "editor.lineHighlightBackground":             "#323232",
    "editor.selectionBackground":                 "#214283",
    "editor.selectionHighlightBackground":        "#1D4165",
    "editor.inactiveSelectionBackground":         "#2A3A54",
    "editor.wordHighlightBackground":             "#1D3A5E",
    "editor.wordHighlightStrongBackground":       "#1D4E89",
    "editor.findMatchBackground":                 "#7B5100",
    "editor.findMatchHighlightBackground":        "#4D3B00",
    "editor.rangeHighlightBackground":            "#FFFFFF0B",
    "editorLineNumber.foreground":                "#606366",
    "editorLineNumber.activeForeground":          "#A4A3A3",
    "editorCursor.foreground":                    "#BBBBBB",
    "editorWhitespace.foreground":                "#3B3B3B",
    "editorIndentGuide.background":               "#3B3B3B",
    "editorIndentGuide.activeBackground":         "#5C5C5C",
    "editorRuler.foreground":                     "#3B3B3B",
    "editorBracketMatch.background":              "#3B514D",
    "editorBracketMatch.border":                  "#3B514D",
    "editorError.foreground":                     "#BC3F3C",
    "editorWarning.foreground":                   "#A08000",
    "editorInfo.foreground":                      "#628FB6",
    "editorGutter.background":                    "#313335",
    "editorGutter.modifiedBackground":            "#4A6F8A",
    "editorGutter.addedBackground":               "#384C38",
    "editorGutter.deletedBackground":             "#4B1818",

    "activityBar.background":                     "#3C3F41",
    "activityBar.foreground":                     "#AFB1B3",
    "activityBar.border":                         "#282828",
    "activityBarBadge.background":                "#4A88C7",
    "activityBarBadge.foreground":                "#FFFFFF",

    "sideBar.background":                         "#3C3F41",
    "sideBar.foreground":                         "#AFB1B3",
    "sideBar.border":                             "#282828",
    "sideBarTitle.foreground":                    "#919294",
    "sideBarSectionHeader.background":            "#3C3F41",
    "sideBarSectionHeader.foreground":            "#919294",
    "sideBarSectionHeader.border":                "#282828",

    "list.activeSelectionBackground":             "#4B6EAF",
    "list.activeSelectionForeground":             "#FFFFFF",
    "list.inactiveSelectionBackground":           "#393D40",
    "list.inactiveSelectionForeground":           "#A9B7C6",
    "list.hoverBackground":                       "#4B4F52",
    "list.focusBackground":                       "#3B4252",
    "list.highlightForeground":                   "#589DF6",

    "statusBar.background":                       "#4E5254",
    "statusBar.foreground":                       "#909294",
    "statusBar.border":                           "#282828",
    "statusBar.debuggingBackground":              "#8A0000",
    "statusBar.debuggingForeground":              "#FFFFFF",
    "statusBar.noFolderBackground":               "#4E5254",
    "statusBarItem.hoverBackground":              "#6B7070",
    "statusBarItem.activeBackground":             "#5B6060",

    "titleBar.activeBackground":                  "#3C3F41",
    "titleBar.activeForeground":                  "#BBBBBB",
    "titleBar.inactiveBackground":                "#3C3F41",
    "titleBar.inactiveForeground":                "#777777",
    "titleBar.border":                            "#282828",

    "tab.activeBackground":                       "#2B2B2B",
    "tab.activeForeground":                       "#BBBBBB",
    "tab.inactiveBackground":                     "#3C3F41",
    "tab.inactiveForeground":                     "#888888",
    "tab.border":                                 "#282828",
    "tab.activeBorder":                           "#4A88C7",
    "tab.unfocusedActiveBorder":                  "#555555",
    "editorGroupHeader.tabsBackground":           "#3C3F41",

    "panel.background":                           "#2B2B2B",
    "panel.border":                               "#3C3F41",
    "panelTitle.activeBorder":                    "#4A88C7",
    "panelTitle.activeForeground":                "#A9B7C6",
    "panelTitle.inactiveForeground":              "#777777",

    "terminal.background":                        "#2B2B2B",
    "terminal.foreground":                        "#A9B7C6",
    "terminal.ansiBlack":                         "#3E3E3E",
    "terminal.ansiRed":                           "#FF5555",
    "terminal.ansiGreen":                         "#50FA7B",
    "terminal.ansiYellow":                        "#F1FA8C",
    "terminal.ansiBlue":                          "#5AA4F5",
    "terminal.ansiMagenta":                       "#BD93F9",
    "terminal.ansiCyan":                          "#8BE9FD",
    "terminal.ansiWhite":                         "#BBD3E1",
    "terminal.ansiBrightBlack":                   "#555555",
    "terminal.ansiBrightRed":                     "#FF6E6E",
    "terminal.ansiBrightGreen":                   "#69FF94",
    "terminal.ansiBrightYellow":                  "#FFFFA5",
    "terminal.ansiBrightBlue":                    "#74B8FA",
    "terminal.ansiBrightMagenta":                 "#D6ACFF",
    "terminal.ansiBrightCyan":                    "#A4FFFF",
    "terminal.ansiBrightWhite":                   "#E6F3F8",
    "terminal.selectionBackground":               "#214283",

    "scrollbar.shadow":                           "#000000",
    "scrollbarSlider.background":                 "#4E5254AA",
    "scrollbarSlider.hoverBackground":            "#646769AA",
    "scrollbarSlider.activeBackground":           "#909294AA",

    "dropdown.background":                        "#3C3F41",
    "dropdown.foreground":                        "#A9B7C6",
    "dropdown.border":                            "#555555",
    "input.background":                           "#45494A",
    "input.foreground":                           "#BBBBBB",
    "input.border":                               "#646464",
    "input.placeholderForeground":                "#808080",
    "inputOption.activeBackground":               "#4B6EAF",
    "inputOption.activeBorder":                   "#4B6EAF",

    "button.background":                          "#4A88C7",
    "button.foreground":                          "#FFFFFF",
    "button.hoverBackground":                     "#5599D8",

    "badge.background":                           "#4A88C7",
    "badge.foreground":                           "#FFFFFF",

    "progressBar.background":                     "#4A88C7",

    "focusBorder":                                "#4A88C7",
    "foreground":                                 "#A9B7C6",
    "widget.shadow":                              "#000000",
    "selection.background":                       "#214283",
    "descriptionForeground":                      "#808080",
    "errorForeground":                            "#F85149",

    "editorHoverWidget.background":               "#2B2B2B",
    "editorHoverWidget.border":                   "#555555",
    "editorSuggestWidget.background":             "#2B2B2B",
    "editorSuggestWidget.border":                 "#555555",
    "editorSuggestWidget.foreground":             "#A9B7C6",
    "editorSuggestWidget.highlightForeground":    "#589DF6",
    "editorSuggestWidget.selectedBackground":     "#3B4970",
    "editorSuggestWidget.selectedForeground":     "#FFFFFF",

    "peekView.border":                            "#4A88C7",
    "peekViewEditor.background":                  "#1F2430",
    "peekViewEditorGutter.background":            "#1F2430",
    "peekViewResult.background":                  "#2B2B2B",
    "peekViewResult.fileForeground":              "#A9B7C6",
    "peekViewResult.lineForeground":              "#A9B7C6",
    "peekViewResult.selectionBackground":         "#3B4970",
    "peekViewResult.selectionForeground":         "#FFFFFF",
    "peekViewTitle.background":                   "#2B2B2B",
    "peekViewTitleDescription.foreground":        "#888888",
    "peekViewTitleLabel.foreground":              "#BBBBBB",

    "gitDecoration.addedResourceForeground":      "#629755",
    "gitDecoration.conflictingResourceForeground": "#C75450",
    "gitDecoration.deletedResourceForeground":    "#C75450",
    "gitDecoration.ignoredResourceForeground":    "#606366",
    "gitDecoration.modifiedResourceForeground":   "#6897BB",
    "gitDecoration.untrackedResourceForeground":  "#629755",

    "notifications.background":                   "#3C3F41",
    "notifications.border":                       "#555555",
    "notifications.foreground":                   "#A9B7C6",
    "notificationCenterHeader.background":        "#3C3F41",

    "breadcrumb.foreground":                      "#808080",
    "breadcrumb.focusForeground":                 "#A9B7C6",
    "breadcrumb.activeSelectionForeground":       "#CCCCCC",
    "breadcrumbPicker.background":                "#2B2B2B",

    "symbolIcon.classForeground":                 "#FFFE8B",
    "symbolIcon.interfaceForeground":             "#9876AA",
    "symbolIcon.functionForeground":              "#FFC66D",
    "symbolIcon.methodForeground":                "#FFC66D",
    "symbolIcon.fieldForeground":                 "#A9B7C6",
    "symbolIcon.variableForeground":              "#A9B7C6",
    "symbolIcon.keywordForeground":               "#CC7832",
    "symbolIcon.enumForeground":                  "#FFC66D",
    "symbolIcon.enumMemberForeground":            "#6897BB"
  },

  "tokenColors": [

    {
      "name": "Comments",
      "scope": [
        "comment",
        "comment.line",
        "comment.line.number-sign",
        "comment.block",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#808080",
        "fontStyle": "italic"
      }
    },

    {
      "name": "Docstrings",
      "scope": [
        "string.quoted.docstring",
        "string.quoted.docstring.tauraro"
      ],
      "settings": {
        "foreground": "#629755",
        "fontStyle": "italic"
      }
    },

    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.double",
        "string.quoted.single",
        "string.quoted.raw",
        "string.quoted.bytes",
        "string.interpolated",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#6A8759"
      }
    },

    {
      "name": "F-String Interpolation Braces",
      "scope": [
        "punctuation.section.embedded",
        "punctuation.section.embedded.begin",
        "punctuation.section.embedded.end"
      ],
      "settings": {
        "foreground": "#CC7832",
        "fontStyle": "bold"
      }
    },

    {
      "name": "F-String Embedded Expression",
      "scope": [
        "meta.embedded.expression",
        "meta.embedded.expression.tauraro"
      ],
      "settings": {
        "foreground": "#A9B7C6"
      }
    },

    {
      "name": "Escape Sequences",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#CC7832",
        "fontStyle": "bold"
      }
    },

    {
      "name": "Keywords — Control Flow",
      "scope": [
        "keyword.control",
        "keyword.control.tauraro",
        "keyword.control.exception",
        "keyword.control.import",
        "keyword.control.async",
        "keyword.control.extern"
      ],
      "settings": {
        "foreground": "#CC7832",
        "fontStyle": "bold"
      }
    },

    {
      "name": "Keywords — Declarations (def, class, etc.)",
      "scope": [
        "keyword.declaration",
        "keyword.declaration.tauraro",
        "keyword.declaration.function",
        "keyword.declaration.class",
        "keyword.declaration.interface",
        "keyword.declaration.enum",
        "keyword.declaration.struct",
        "keyword.declaration.extend"
      ],
      "settings": {
        "foreground": "#CC7832",
        "fontStyle": "bold"
      }
    },

    {
      "name": "Keywords — Operator Words (and, or, not)",
      "scope": [
        "keyword.operator.word",
        "keyword.operator.word.tauraro"
      ],
      "settings": {
        "foreground": "#CC7832",
        "fontStyle": "bold"
      }
    },

    {
      "name": "Hausa Keywords (bilingual)",
      "scope": [
        "keyword.other.hausa",
        "keyword.other.hausa.tauraro"
      ],
      "settings": {
        "foreground": "#FF9A3C",
        "fontStyle": "bold italic"
      }
    },

    {
      "name": "Storage Modifiers (pub, mut, static, const)",
      "scope": [
        "storage.modifier",
        "storage.modifier.tauraro"
      ],
      "settings": {
        "foreground": "#4A9EFF",
        "fontStyle": "bold"
      }
    },

    {
      "name": "Class Names",
      "scope": [
        "entity.name.type.class",
        "entity.name.type.class.tauraro",
        "entity.name.type.interface",
        "entity.name.type.interface.tauraro",
        "entity.name.type.enum",
        "entity.name.type.enum.tauraro",
        "entity.name.type.struct",
        "entity.name.type.struct.tauraro",
        "entity.name.type",
        "entity.name.type.tauraro"
      ],
      "settings": {
        "foreground": "#FFFE8B"
      }
    },

    {
      "name": "Function / Method Names (definitions)",
      "scope": [
        "entity.name.function",
        "entity.name.function.tauraro",
        "entity.name.function.method",
        "entity.name.function.method.tauraro"
      ],
      "settings": {
        "foreground": "#FFC66D"
      }
    },

    {
      "name": "Function Calls",
      "scope": [
        "entity.name.function.call",
        "entity.name.function.call.tauraro",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#FFC66D"
      }
    },

    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "entity.name.function.decorator.tauraro",
        "punctuation.definition.decorator",
        "punctuation.definition.decorator.tauraro"
      ],
      "settings": {
        "foreground": "#BBB529"
      }
    },

    {
      "name": "Namespaces / Modules",
      "scope": [
        "entity.name.namespace",
        "entity.name.namespace.tauraro"
      ],
      "settings": {
        "foreground": "#A9B7C6"
      }
    },

    {
      "name": "Built-in Types",
      "scope": [
        "support.type.builtin",
        "support.type.builtin.tauraro",
        "support.type"
      ],
      "settings": {
        "foreground": "#9876AA"
      }
    },

    {
      "name": "Built-in Exception Types",
      "scope": [
        "support.type.exception",
        "support.type.exception.tauraro"
      ],
      "settings": {
        "foreground": "#9876AA",
        "fontStyle": "italic"
      }
    },

    {
      "name": "Built-in Functions",
      "scope": [
        "support.function.builtin",
        "support.function.builtin.tauraro",
        "support.function"
      ],
      "settings": {
        "foreground": "#6897BB"
      }
    },

    {
      "name": "Language Constants (true, false, none)",
      "scope": [
        "constant.language",
        "constant.language.tauraro"
      ],
      "settings": {
        "foreground": "#6897BB",
        "fontStyle": "bold"
      }
    },

    {
      "name": "Numeric Literals",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.binary",
        "constant.numeric.octal",
        "constant.numeric.scientific"
      ],
      "settings": {
        "foreground": "#6897BB"
      }
    },

    {
      "name": "Self / This",
      "scope": [
        "variable.language.this",
        "variable.language.this.tauraro"
      ],
      "settings": {
        "foreground": "#94E2D5",
        "fontStyle": "italic"
      }
    },

    {
      "name": "Operators — Arrow (->)",
      "scope": [
        "keyword.operator.arrow",
        "keyword.operator.arrow.tauraro"
      ],
      "settings": {
        "foreground": "#CC7832",
        "fontStyle": "bold"
      }
    },

    {
      "name": "Operators — Fat Arrow (=>)",
      "scope": [
        "keyword.operator.fat-arrow",
        "keyword.operator.fat-arrow.tauraro"
      ],
      "settings": {
        "foreground": "#CC7832",
        "fontStyle": "bold"
      }
    },

    {
      "name": "Operators — Comparison",
      "scope": [
        "keyword.operator.comparison",
        "keyword.operator.comparison.tauraro"
      ],
      "settings": {
        "foreground": "#A9B7C6"
      }
    },

    {
      "name": "Operators — Assignment",
      "scope": [
        "keyword.operator.assignment",
        "keyword.operator.assignment.tauraro",
        "keyword.operator.assignment.compound"
      ],
      "settings": {
        "foreground": "#A9B7C6"
      }
    },

    {
      "name": "Operators — Arithmetic",
      "scope": [
        "keyword.operator.arithmetic",
        "keyword.operator.arithmetic.tauraro"
      ],
      "settings": {
        "foreground": "#A9B7C6"
      }
    },

    {
      "name": "Operators — Bitwise",
      "scope": [
        "keyword.operator.bitwise",
        "keyword.operator.bitwise.tauraro"
      ],
      "settings": {
        "foreground": "#A9B7C6"
      }
    },

    {
      "name": "Operators — Nullable (??, !!, ?)",
      "scope": [
        "keyword.operator.nullable",
        "keyword.operator.nullable.tauraro"
      ],
      "settings": {
        "foreground": "#FFC66D"
      }
    },

    {
      "name": "Punctuation — Colon",
      "scope": [
        "keyword.operator.colon",
        "keyword.operator.colon.tauraro",
        "punctuation.separator.colon"
      ],
      "settings": {
        "foreground": "#A9B7C6"
      }
    },

    {
      "name": "Punctuation — Brackets & Parentheses",
      "scope": [
        "punctuation.brackets",
        "punctuation.definition.parameters",
        "meta.brace.round",
        "meta.brace.square",
        "meta.brace.curly"
      ],
      "settings": {
        "foreground": "#A9B7C6"
      }
    },

    {
      "name": "Function Parameters",
      "scope": [
        "variable.parameter",
        "variable.parameter.function"
      ],
      "settings": {
        "foreground": "#A9B7C6",
        "fontStyle": "italic"
      }
    },

    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#A9B7C6"
      }
    },

    {
      "name": "Invalid / Deprecated",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FF5555",
        "fontStyle": "underline"
      }
    },

    {
      "name": "Markup — Bold",
      "scope": ["markup.bold"],
      "settings": { "fontStyle": "bold", "foreground": "#BBBBBB" }
    },
    {
      "name": "Markup — Italic",
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic", "foreground": "#BBBBBB" }
    },
    {
      "name": "Markup — Heading",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#FFC66D", "fontStyle": "bold" }
    },
    {
      "name": "Markup — Code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": { "foreground": "#6A8759" }
    },
    {
      "name": "Markup — Link",
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#6897BB", "fontStyle": "underline" }
    }
  ],

  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class":              { "foreground": "#FFFE8B" },
    "interface":          { "foreground": "#FFFE8B", "fontStyle": "italic" },
    "enum":               { "foreground": "#FFFE8B" },
    "struct":             { "foreground": "#FFFE8B" },
    "enumMember":         { "foreground": "#6897BB", "fontStyle": "bold" },
    "function":           { "foreground": "#FFC66D" },
    "method":             { "foreground": "#FFC66D" },
    "decorator":          { "foreground": "#BBB529" },
    "parameter":          { "foreground": "#A9B7C6", "fontStyle": "italic" },
    "variable":           { "foreground": "#A9B7C6" },
    "property":           { "foreground": "#A9B7C6" },
    "type":               { "foreground": "#9876AA" },
    "typeParameter":      { "foreground": "#9876AA", "fontStyle": "italic" },
    "namespace":          { "foreground": "#A9B7C6" },
    "keyword":            { "foreground": "#CC7832", "fontStyle": "bold" },
    "modifier":           { "foreground": "#4A9EFF", "fontStyle": "bold" },
    "number":             { "foreground": "#6897BB" },
    "string":             { "foreground": "#6A8759" },
    "comment":            { "foreground": "#808080", "fontStyle": "italic" },
    "selfKeyword":        { "foreground": "#94E2D5", "fontStyle": "italic" },
    "builtinType":        { "foreground": "#9876AA" },
    "lifetime":           { "foreground": "#FFB86C", "fontStyle": "italic" }
  }
}
